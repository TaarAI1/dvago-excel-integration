# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017
# Railway/Atlas: mongodb+srv://user:pass@cluster.mongodb.net/retailpro_integration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=retailpro_integration

# ─── FTP Server ────────────────────────────────────────────────────────────────
FTP_HOST=ftp.example.com
FTP_PORT=21
FTP_USER=ftpuser
FTP_PASSWORD=ftppassword
FTP_BASE_PATH=/csv_exports

# ─── RetailPro Prism API ────────────────────────────────────────────────────────
RETAILPRO_BASE_URL=https://your-retailpro-server.com/api
RETAILPRO_API_KEY=your-api-key-here
# Set to "real" when ready to use the live API; "mock" for development/testing
RETAILPRO_CLIENT=mock

# Document type → API endpoint mapping (JSON)
# Keys must match inferred document types from CSV filenames
DOCUMENT_TYPE_ENDPOINTS={"item_master": "/v1/items", "receiving_voucher": "/v1/receiving", "inventory_adjustment": "/v1/inventory"}

# CSV column → MongoDB field name mapping per document type (JSON)
# Leave empty {} if column names should be used as-is
# Example: {"item_master": {"ItemCode": "sku", "ItemDescription": "name", "UnitCost": "cost"}}
DOCUMENT_TYPE_FIELD_MAPS={}

# ─── Authentication ─────────────────────────────────────────────────────────────
# Dashboard login credentials
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me_in_production

# JWT — use a long random string in production
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ─── Scheduler ─────────────────────────────────────────────────────────────────
# Cron expression for FTP polling (default: every 15 minutes)
# Examples: "*/5 * * * *" = every 5 min | "0 * * * *" = every hour
POLL_CRON_SCHEDULE=*/15 * * * *
